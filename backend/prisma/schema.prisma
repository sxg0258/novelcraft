// Prisma schema for NovelCraft
// MVP 阶段：用户认证先简化（单用户/无密码），角色与设定卡暂留接口

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户
model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String?   @db.Text
  nickname     String?
  avatar       String?
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
  books        Book[]
  sessions     UserSession[]
}

// 书
model Book {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title     String   @db.VarChar(200)
  coverUrl  String?
  summary   String?  @db.Text
  status    String   @default("drafting") // drafting / archiving / completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapters       Chapter[]
  characters     Character[]
  worldItems     WorldItem[]
  customFieldDefs CustomFieldDef[]
  outlines       Outline[]
  aiStyles       AiStyle[]
  aiConversations AiConversation[]

  @@index([userId])
  @@index([updatedAt])
}

// 章节（树形，parentId 自引用）
model Chapter {
  id           String   @id @default(uuid())
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       Chapter? @relation("ChapterHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Chapter[] @relation("ChapterHierarchy")
  title        String   @db.VarChar(200)
  content      Json     @default("{\"type\":\"doc\",\"content\":[]}")
  contentText  String?  @db.Text
  wordCount    Int      @default(0)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bookId])
  @@index([bookId, parentId])

  snapshots ChapterSnapshot[]
}

// 角色
model Character {
  id         String   @id @default(uuid())
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  name       String   @db.VarChar(100)
  avatarUrl  String?
  attributes Json     @default("{}")
  relations  Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([bookId])
}

// 设定项（通用：地点/物品/势力/技能）
model WorldItem {
  id         String   @id @default(uuid())
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category   String   @db.VarChar(50) // location / item / faction / skill / other
  name       String   @db.VarChar(100)
  attributes Json     @default("{}")
  tags       String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([bookId])
  @@index([bookId, category])
}

// 自定义字段定义
model CustomFieldDef {
  id         String   @id @default(uuid())
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  targetType String   @db.VarChar(20) // 'character' / 'world_item'
  name       String   @db.VarChar(50)
  fieldType  String   @db.VarChar(20) // text / number / enum / date / url
  config     Json     @default("{}")  // enum 选项等
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([bookId, targetType])
}

// 大纲节点
model Outline {
  id        String   @id @default(uuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Outline? @relation("OutlineHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Outline[] @relation("OutlineHierarchy")
  title     String   @db.VarChar(200)
  content   String?  @db.Text
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookId])
}

// AI 风格预设（书级别）
model AiStyle {
  id               String   @id @default(uuid())
  bookId           String
  book             Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  name             String   @db.VarChar(100)
  description      String?  @db.Text
  systemPrompt     String?  @db.Text
  temperature      Float    @default(0.7)
  topP             Float    @default(1.0)
  frequencyPenalty Float    @default(0.0)
  presencePenalty  Float    @default(0.0)
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([bookId])
}

// AI 对话
model AiConversation {
  id        String   @id @default(uuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapterId String?
  aiStyleId String?
  provider  String   @db.VarChar(50)
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookId])
  @@index([chapterId])
}

// 每日字数快照（用于热力图）
// 一天一条记录，写入或更新时记录总字数
model DailySnapshot {
  id        String   @id @default(uuid())
  bookId    String
  date      String   @db.VarChar(10)  // YYYY-MM-DD
  wordCount Int      @default(0)
  delta     Int      @default(0)      // 当日新增字数（相对前日）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookId, date])
  @@index([bookId, date])
}

// AI Provider 配置（全局，一本书可选用任意 provider）
// 敏感字段（apiKey）加密存到文件，DB 里只存引用
model AiProvider {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(50)   // 显示名，如"我的 DeepSeek"
  provider    String   @db.VarChar(50)   // openai / anthropic / deepseek / qwen / glm / ollama / custom
  baseUrl     String?  @db.Text          // 自定义 endpoint（custom 必须）
  apiKey      String?  @db.Text          // API key（Ollama 不用）
  defaultModel String? @db.VarChar(100)  // 默认模型
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AI 对话会话（按 chapter 隔离）
model AiChat {
  id          String   @id @default(uuid())
  bookId      String
  chapterId   String?
  aiStyleId   String?
  providerId  String?  // 选用的 provider
  model       String?  // 当时用的模型
  mode        String   @db.VarChar(20)   // continue / polish / chat
  title       String?  // 自动生成或用户改
  messages    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([bookId])
  @@index([chapterId])
}

// 章节历史快照（用于版本回溯 + diff）
// 自动保存时每 N 分钟拍一张快照，最多保留 N 张
model ChapterSnapshot {
  id          String   @id @default(uuid())
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title       String   @db.VarChar(200)
  content     Json
  contentText String?  @db.Text
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([chapterId, createdAt])
}

// 协同文档状态（Yjs 文档二进制快照，按需加载）
model CollabState {
  id        String   @id @default(uuid())
  chapterId String   @unique
  state     Bytes
  updatedAt DateTime @updatedAt
}

// 用户登录会话（JWT refresh token）
model UserSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique @db.Text
  userAgent    String?  @db.Text
  ip           String?  @db.VarChar(64)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}
